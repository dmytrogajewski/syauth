<?xml version="1.0" encoding="utf-8"?>
<!--
  syauth launcher icon foreground: shield with a key inside.

  Mirrors the prrr-android shield+lock motif so the sibling apps look
  like they ship from the same operator. The key replaces prrr's lock
  symbol because syauth's metaphor is "phone-as-key": the phone holds
  the Ed25519 secret that unlocks the desktop's PAM stack.

  Adaptive-icon foreground convention: 108dp square, the centred 72dp
  inner region is guaranteed visible across launcher mask shapes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield body (white). -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,24L30,34v15c0,16.5 10.2,31.9 24,36 13.8,-4.1 24,-19.5 24,-36V34L54,24z"/>

    <!-- Key (success green) inside the shield: circular bow on the
         left + rectangular shaft + two teeth on the right. -->
    <path
        android:fillColor="#22C55E"
        android:pathData="M44,54a6,6 0 1,1 12,0 6,6 0 1,1 -12,0z
M56,52h16v4h-3v3h-3v-3h-3v3h-3v-3h-4z"/>

    <!-- Inner punch on the key bow so the metaphor reads at small sizes. -->
    <path
        android:fillColor="#000000"
        android:pathData="M48,54a2,2 0 1,1 4,0 2,2 0 1,1 -4,0z"/>
</vector>

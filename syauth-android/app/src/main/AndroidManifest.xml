<?xml version="1.0" encoding="utf-8"?>
<!--
  Roadmap items S-016 (BLE pairing) and S-017 (BiometricPrompt) — manifest
  carries the runtime permissions the pairing screen and the Approve screen
  need.

  Permission contract (audited in
  specs/journeys/JOURNEY-S-016-android-pairing.md "Bluetooth Permission
  Contract" and specs/journeys/JOURNEY-S-017-android-approve.md):

    - BLUETOOTH_SCAN     — scan for advertising peers (S-016 Phase 2).
                           Runtime permission on API 31+.
                           `neverForLocation` flag asserts we don't infer
                           location from scan results (we don't — the
                           desktop advertises a rotating UUID, not a
                           position).
    - BLUETOOTH_CONNECT  — connect to a chosen peer + initiate LESC
                           bonding (S-016 Phase 3). Runtime permission
                           on API 31+.
    - ACCESS_FINE_LOCATION (maxSdkVersion=30) — legacy: BLE scans on
                           API 26-30 require location. The cap prevents
                           the dialog from showing on API 31+.
    - USE_BIOMETRIC      — gates the Keystore-backed signing key on a
                           fresh user gesture via BiometricPrompt
                           (S-017 Approve screen).

  Explicitly NOT declared (still owned by future roadmap items):
    - INTERNET             — never (BLE-only protocol per SPEC §3.4).
    - BLUETOOTH_ADVERTISE  — never (desktop advertises; phone scans —
                              SPEC §3.2 D8, presence-tracking defense).
    - POST_NOTIFICATIONS   — S-018 (CompanionDeviceService).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BLE scan: required to discover advertising desktops in S-016 Phase 2. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31" />

    <!-- BLE connect + LESC bond: S-016 Phase 3. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31" />

    <!-- Legacy: BLE scans on API 26-30 require ACCESS_FINE_LOCATION. -->
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <!--
      S-017: BiometricPrompt gate for the Keystore-backed signing key.
      Required by androidx.biometric:biometric 1.2.0-alpha05.
    -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SyauthAndroid"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SyauthAndroid">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>

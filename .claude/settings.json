{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/ban-filler-word.sh\"",
            "statusMessage": "Checking for banned word 'pre-existing'"
          }
        ]
      }
    ]
  }
}

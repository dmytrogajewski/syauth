# Shared version + minimum-supported-platform constants for the S-021
# release pipeline. Sourced by `Makefile` (the `dist` / `rpm` / `deb`
# targets), `scripts/smoke-install.sh` (the docker images it pulls), and
# documented in `deploy/fedora/syauth.spec`, `deploy/debian/control`,
# and `.github/workflows/release.yml`. Keep this the single source of
# truth — duplicate the value in another file only if you also update
# this file in the same commit.
#
# Format: POSIX shell `KEY=VALUE`, no spaces around `=`, no quoting
# unless the value contains whitespace. Safe to `source` from bash/sh.

# The wire-shipped package version. Mirrors the Rust workspace's
# `[workspace.package].version` field in /Cargo.toml. Bump in lockstep.
PACKAGE_VERSION=0.1.0

# RPM release counter (the `-1` in `syauth-0.1.0-1.fc39.x86_64.rpm`).
# Bump only if a respin is needed without changing the source version.
RPM_RELEASE=1

# Debian revision (the `-1` in `syauth_0.1.0-1_amd64.deb`). Same rule
# as RPM_RELEASE.
DEB_REVISION=1

# Minimum Fedora release the spec targets. The spec's `BuildRequires:
# fedora-release >= …` plus the docker image used by
# scripts/smoke-install.sh both reference this number.
MIN_FEDORA=39

# Minimum Debian release. The deb's runtime deps (`libpam0g (>= 1.5)`,
# `bluez (>= 5.66)`) match this version's archive.
MIN_DEBIAN=12

# Minimum Ubuntu LTS release. Ubuntu 22.04 ships libpam0g 1.4.0; we
# require 1.5+ for the modern conv pointer ABI, so the practical
# minimum is Ubuntu 24.04 LTS in production. The control file's
# `Depends:` line is the binding constraint; this constant exists for
# the README.
MIN_UBUNTU=22.04

# Minimum Rust toolchain. Matches the workspace's
# `[workspace.package].rust-version`. Both the spec's BuildRequires
# and the deb's Build-Depends pin this.
MIN_RUST=1.85

# Minimum Android API level. Mirrors syauth-android's
# `defaultConfig.minSdk` (= 26, Android 8.0 Oreo).
MIN_ANDROID_API=26
